# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

BASE_URL="http://localhost:3000"

DATABASE_PATH="./data/sqlite.db"
DATABASE_URL="file:./data/sqlite.db"

# Image store backend: "volume" (on-disk files) or "tigris" (S3-compatible bucket).
IMAGE_STORE_DRIVER="volume"

# Root path of the on-disk image store (volume driver).
# Production (Fly volume): /data/images. Local development: ./data/images.
IMAGE_STORE_PATH="./data/images"

# Tigris/S3 credentials — only used when IMAGE_STORE_DRIVER="tigris".
# On Fly these are set automatically by `fly storage create`.
# AWS_ACCESS_KEY_ID="tid_..."
# AWS_SECRET_ACCESS_KEY="tsec_..."
# AWS_REGION="auto"
# AWS_ENDPOINT_URL_S3="https://fly.storage.tigris.dev"
# BUCKET_NAME="cz-vednemesicnik-images"

SESSION_SECRET="dummy_session_secret"
HONEYPOT_SECRET="dummy_honeypot_secret"

RELYING_PARTY_NAME="My App"
RELYING_PARTY_ID="localhost"
RELYING_PARTY_ORIGIN="http://localhost:3000"
