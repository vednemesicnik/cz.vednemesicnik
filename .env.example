# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

BASE_URL="http://localhost:3000"

DATABASE_PATH="./data/sqlite.db"
DATABASE_URL="file:./data/sqlite.db"

# Object store backend for images and PDFs: "volume" (on-disk files) or "tigris"
# (S3-compatible bucket). One toggle for every store.
STORE_DRIVER="volume"

# Root paths of the on-disk stores (volume driver).
# Production (Fly volume): /data/images, /data/pdfs. Local development: ./data/*.
IMAGE_STORE_PATH="./data/images"
PDF_STORE_PATH="./data/pdfs"

# Tigris/S3 credentials — only used when STORE_DRIVER="tigris".
# On Fly these are set automatically by `fly storage create`.
# Images live under the "images/" prefix and PDFs under "pdfs/" in the same bucket.
# AWS_ACCESS_KEY_ID="tid_..."
# AWS_SECRET_ACCESS_KEY="tsec_..."
# AWS_REGION="auto"
# AWS_ENDPOINT_URL_S3="https://fly.storage.tigris.dev"
# BUCKET_NAME="cz-vednemesicnik-storage"

SESSION_SECRET="dummy_session_secret"
HONEYPOT_SECRET="dummy_honeypot_secret"

# WebAuthn relying party for passkey sign-in. Required in production, optional
# locally (these localhost defaults just work). RELYING_PARTY_ID is the domain
# only — no scheme, no port; RELYING_PARTY_ORIGIN is the exact origin the browser
# sees (scheme + host + port), no trailing slash. In production ID should be the
# registrable domain (e.g. "vednemesicnik.cz") so passkeys work across subdomains.
# Changing ID later invalidates every existing passkey.
RELYING_PARTY_NAME="Vedneměsíčník"
RELYING_PARTY_ID="localhost"
RELYING_PARTY_ORIGIN="http://localhost:3000"

# Break-glass password sign-in. The password form is a last-resort emergency
# path: the system treats it as DISABLED whenever this variable is unset or not
# exactly "true". This example sets "true" on purpose — until an alternative
# sign-in method (magic link / OAuth) ships, "true" is the only way to sign in.
# Set to "false" (or remove it) once an alternative is deployed.
ALLOW_PASSWORD_SIGN_IN="true"

# Google OAuth (Workspace SSO). From a Web OAuth client in Google Cloud Console.
# The redirect URI is derived from BASE_URL (…/administration/sign-in/google/callback)
# and must be registered on the client. Required in production. Unset locally →
# the Google button errors on submit; the other sign-in methods keep working.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Magic-link email via Google Apps Script (SCRIPT__Auth__Magic_Link web app).
# Required in production. Unset locally → the sign-in flow works but no email is
# sent (the link is logged). GAS_MAGIC_LINK_URL is the web app /exec URL;
# GAS_MAGIC_LINK_SECRET must match the script's SHARED_SECRET property.
# GAS_MAGIC_LINK_URL=""
# GAS_MAGIC_LINK_SECRET=""
