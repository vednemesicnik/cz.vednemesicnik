generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider     = "sqlite"
  relationMode = "foreignKeys"
}

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  username    String       @unique
  name        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  image       UserImage?
  password    Password?
  role        UserRole     @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  roleId      String
  sessions    Session[]
  passkeys    Passkey[]
  connections Connection[]
  backupCodes BackupCode[]
  author      Author       @relation(fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  authorId    String       @unique
}

model UserImage {
  id                 String   @id @default(cuid())
  altText            String?
  // Image store metadata (see app/utils/image-store).
  version            String
  intrinsicWidth     Int
  intrinsicHeight    Int
  placeholderDataUrl String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId             String   @unique
}

model Password {
  hash   String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String @unique
}

model UserRole {
  id          String           @id @default(cuid())
  name        UserRoleName     @unique
  level       Int
  description String           @default("")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       User[]
  permissions UserPermission[]
}

enum UserRoleName {
  owner
  administrator
  member
}

model UserPermission {
  id          String               @id @default(cuid())
  action      UserPermissionAction
  entity      UserPermissionEntity
  access      UserPermissionAccess
  description String               @default("")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  roles       UserRole[]

  @@unique([action, entity, access])
}

enum UserPermissionAction {
  view
  create
  update
  delete
}

enum UserPermissionEntity {
  user
  author
}

enum UserPermissionAccess {
  own
  any
}

model Session {
  id             String   @id @default(cuid())
  expirationDate DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId         String

  // non-unique foreign key
  @@index([userId])
}

model Passkey {
  id                   String   @id @default(cuid())
  credentialId         String   @unique
  credentialPublicKey  Bytes
  credentialCounter    BigInt
  credentialTransports String
  credentialDeviceType String
  credentialBackedUp   Boolean
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId               String

  // non-unique foreign key
  @@index([userId])
}

model Connection {
  id           String   @id @default(cuid())
  providerName String
  providerId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId       String

  @@unique([providerName, providerId])
  // non-unique foreign key
  @@index([userId])
}

model Verification {
  id        String    @id @default(cuid())
  // The type of verification, e.g. "email" or "phone"
  type      String
  // The thing we're trying to verify, e.g. a user's email or phone number
  target    String
  // The secret: the otp seed (TOTP) or the hashed token (magic link)
  secret    String
  // The algorithm used to generate the otp; null for non-otp types (magic link)
  algorithm String?
  // The number of digits in the otp; null for non-otp types (magic link)
  digits    Int?
  // The number of seconds the otp is valid for; null for non-otp types (magic link)
  period    Int?
  // The valid characters for the otp; null for non-otp types (magic link)
  charSet   String?
  // When it's safe to delete this verification
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([target, type])
}

// Single-use backup (recovery) codes: a fallback second factor for the
// break-glass password + TOTP flow. One row per code, hashed at rest (bcrypt,
// like Password.hash); redemption sets usedAt so a code works only once.
model BackupCode {
  id        String    @id @default(cuid())
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId    String

  // non-unique foreign key
  @@index([userId])
}

model Author {
  id                String            @id @default(cuid())
  name              String
  bio               String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User?
  role              AuthorRole        @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  roleId            String
  // Authored content
  articles          Article[]         @relation("ArticleAuthors")
  // Created content
  articleTags       ArticleTag[]      @relation("ArticleTagCreator")
  articleCategories ArticleCategory[] @relation("ArticleCategoryCreator")
  issues            Issue[]           @relation("IssueCreator")
  podcasts          Podcast[]         @relation("PodcastCreator")
  podcastEpisodes   PodcastEpisode[]  @relation("PodcastEpisodeCreator")
  pageSEOs          PageSEO[]         @relation("PageSeoCreator")
  // Reviewed content
  reviews           Review[]          @relation("ReviewsGiven")
}

model AuthorRole {
  id          String             @id @default(cuid())
  name        AuthorRoleName     @unique
  level       Int
  description String             @default("")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  authors     Author[]
  permissions AuthorPermission[]
}

enum AuthorRoleName {
  coordinator
  creator
  contributor
}

model AuthorPermission {
  id          String                 @id @default(cuid())
  action      AuthorPermissionAction
  entity      AuthorPermissionEntity
  access      AuthorPermissionAccess
  state       ContentState
  description String                 @default("")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  roles       AuthorRole[]

  @@unique([action, entity, access, state])
}

enum AuthorPermissionAction {
  view
  create
  update
  delete
  publish
  retract
  archive
  restore
  review
}

enum AuthorPermissionEntity {
  article
  article_tag
  article_category
  podcast
  podcast_episode
  issue
  page_seo
}

enum AuthorPermissionAccess {
  own
  any
}

model Issue {
  id          String       @id @default(cuid())
  label       String
  releasedAt  DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  publishedAt DateTime?
  state       ContentState @default(draft)
  cover       IssueCover?
  pdf         IssuePDF?
  author      Author       @relation("IssueCreator", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  authorId    String
  reviews     Review[]     @relation("IssueReviews")

  // non-unique foreign key
  @@index([authorId])
  // content-state query paths (own-access filtering, public list ordering)
  @@index([state, authorId])
  @@index([state, releasedAt])
}

model IssueCover {
  id                 String   @id @default(cuid())
  altText            String
  // Image store metadata (see app/utils/image-store).
  version            String
  intrinsicWidth     Int
  intrinsicHeight    Int
  placeholderDataUrl String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  issue              Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  issueId            String   @unique
}

model IssuePDF {
  id          String   @id @default(cuid())
  fileName    String   @unique
  contentType String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  issue       Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  issueId     String   @unique
}

model Podcast {
  id          String           @id @default(cuid())
  slug        String           @unique
  title       String
  description String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  publishedAt DateTime?
  state       ContentState     @default(draft)
  episodes    PodcastEpisode[]
  cover       PodcastCover?
  author      Author           @relation("PodcastCreator", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  authorId    String
  reviews     Review[]         @relation("PodcastReviews")

  // non-unique foreign key
  @@index([authorId])
  // content-state query paths (own-access filtering, public list ordering)
  @@index([state, authorId])
  @@index([state, publishedAt])
}

model PodcastCover {
  id                 String   @id @default(cuid())
  altText            String
  // Image store metadata (see app/utils/image-store).
  version            String
  intrinsicWidth     Int
  intrinsicHeight    Int
  placeholderDataUrl String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  podcast            Podcast  @relation(fields: [podcastId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  podcastId          String   @unique
}

model PodcastEpisode {
  id          String               @id @default(cuid())
  slug        String               @unique
  number      Int
  title       String
  description String
  links       PodcastEpisodeLink[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  publishedAt DateTime?
  state       ContentState         @default(draft)
  podcast     Podcast              @relation(fields: [podcastId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  podcastId   String
  cover       PodcastEpisodeCover?
  author      Author               @relation("PodcastEpisodeCreator", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  authorId    String
  reviews     Review[]             @relation("PodcastEpisodeReviews")

  // episode number should be unique within a podcast
  @@unique([podcastId, number])
  // non-unique foreign key
  @@index([podcastId])
  @@index([authorId])
  // content-state query paths (own-access filtering, public list ordering)
  @@index([state, authorId])
  @@index([state, publishedAt])
}

model PodcastEpisodeLink {
  id        String         @id @default(cuid())
  url       String
  label     String
  order     Int            @default(0)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  episode   PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  episodeId String

  // non-unique foreign key
  @@index([episodeId])
}

model PodcastEpisodeCover {
  id                 String         @id @default(cuid())
  altText            String
  // Image store metadata (see app/utils/image-store).
  version            String
  intrinsicWidth     Int
  intrinsicHeight    Int
  placeholderDataUrl String
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  episode            PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  episodeId          String         @unique
}

model Article {
  id              String            @id @default(cuid())
  slug            String            @unique
  title           String
  excerpt         String?
  content         String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  publishedAt     DateTime?
  state           ContentState      @default(draft)
  authors         Author[]          @relation("ArticleAuthors")
  images          ArticleImage[]    @relation("ArticleImages")
  featuredImageId String?           @unique
  featuredImage   ArticleImage?     @relation("ArticleFeaturedImage", fields: [featuredImageId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tags            ArticleTag[]
  categories      ArticleCategory[]
  reviews         Review[]          @relation("ArticleReviews")

  // content-state query path (public list ordering; authors are M:N, no authorId FK)
  @@index([state, publishedAt])
}

model ArticleImage {
  id                 String   @id @default(cuid())
  altText            String
  description        String?
  // Image store metadata (see app/utils/image-store).
  version            String
  intrinsicWidth     Int
  intrinsicHeight    Int
  placeholderDataUrl String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  article            Article  @relation("ArticleImages", fields: [articleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  articleId          String
  featuredInArticle  Article? @relation("ArticleFeaturedImage")

  // non-unique foreign key
  @@index([articleId])
}

model ArticleTag {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  publishedAt DateTime?
  state       ContentState @default(draft)
  articles    Article[]
  author      Author       @relation("ArticleTagCreator", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  authorId    String
  reviews     Review[]     @relation("ArticleTagReviews")

  // non-unique foreign key
  @@index([authorId])
  // content-state query path (own-access filtering)
  @@index([state, authorId])
}

model ArticleCategory {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  publishedAt DateTime?
  state       ContentState @default(draft)
  articles    Article[]
  author      Author       @relation("ArticleCategoryCreator", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  authorId    String
  reviews     Review[]     @relation("ArticleCategoryReviews")

  // non-unique foreign key
  @@index([authorId])
  // content-state query path (own-access filtering)
  @@index([state, authorId])
}

model PageSEO {
  id              String       @id @default(cuid())
  pathname        String       @unique
  title           String?
  description     String?
  robots          String       @default("index, follow")
  ogImageUrl      String?
  twitterImageUrl String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  publishedAt     DateTime?
  state           ContentState @default(draft)
  authorId        String
  author          Author       @relation("PageSeoCreator", fields: [authorId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviews         Review[]     @relation("PageSEOReviews")

  // non-unique foreign key
  @@index([authorId])
  // content-state query path (own-access filtering)
  @@index([state, authorId])
}

enum ContentState {
  draft
  published
  archived
}

model Review {
  id                String           @id @default(cuid())
  state             ReviewState      @default(approved)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  reviewerId        String
  reviewer          Author           @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  // Content entity relations
  issueId           String?
  issue             Issue?           @relation("IssueReviews", fields: [issueId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  articleId         String?
  article           Article?         @relation("ArticleReviews", fields: [articleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  podcastId         String?
  podcast           Podcast?         @relation("PodcastReviews", fields: [podcastId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  podcastEpisodeId  String?
  podcastEpisode    PodcastEpisode?  @relation("PodcastEpisodeReviews", fields: [podcastEpisodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  articleTagId      String?
  articleTag        ArticleTag?      @relation("ArticleTagReviews", fields: [articleTagId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  articleCategoryId String?
  articleCategory   ArticleCategory? @relation("ArticleCategoryReviews", fields: [articleCategoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  pageSEOId         String?
  pageSEO           PageSEO?         @relation("PageSEOReviews", fields: [pageSEOId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([reviewerId])
  @@index([issueId])
  @@index([articleId])
  @@index([podcastId])
  @@index([podcastEpisodeId])
  @@index([articleTagId])
  @@index([articleCategoryId])
  @@index([pageSEOId])
}

enum ReviewState {
  approved
}

enum AuthLogEvent {
  sign_in_success
  sign_in_failure
  two_factor_failure
  sign_out
}

enum AuthMethod {
  password
  magic_link
  google
  passkey
  two_factor
  backup_code
}

// Authentication log. Deliberately has no relation to User so events survive
// account deletion. `method` is nullable because sign-out has none.
model AuthLog {
  id        String       @id @default(cuid())
  createdAt DateTime     @default(now())
  event     AuthLogEvent
  method    AuthMethod? // null for sign-out
  userId    String? // set when the user is known
  email     String? // submitted email on failures where no user exists
  ipAddress String?
  userAgent String?

  @@index([createdAt])
  @@index([userId])
}

enum AuditLogEvent {
  user_created
  user_deleted
  user_role_changed
  author_role_changed
}

// Administrative audit log (user management, role changes). Deliberately has no
// relation to User so records survive account deletion. No retention pruning:
// volume is tiny and the forensic value is permanent.
model AuditLog {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  event     AuditLogEvent
  actorId   String // user id of the administrator performing the action
  targetId  String // user id (or author id for author_role_changed) of the affected account
  detail    String? // e.g. "role: member → administrator"
  ipAddress String?

  @@index([createdAt])
  @@index([actorId])
  @@index([targetId])
}
