# Copy to .env for the local production-like container (`pnpm docker:compose:up`).
# BASE_URL, DATABASE_URL, the image/PDF store paths, HOST and PORT are baked into
# docker/local/Dockerfile (the container is served on http://localhost:8080), so
# they are not repeated here. The container runs with NODE_ENV=production, so every
# "required in production" var below must be set — the dummy values are enough to
# boot; real ones are only needed for that feature to actually work.

SESSION_SECRET="dummy_session_secret"
HONEYPOT_SECRET="dummy_honeypot_secret"

# WebAuthn relying party for passkey sign-in. Required in production. RELYING_PARTY_ID
# is the domain only — no scheme, no port; RELYING_PARTY_ORIGIN is the exact origin
# the browser sees (scheme + host + port), no trailing slash. Changing ID later
# invalidates every existing passkey.
RELYING_PARTY_NAME="Vedneměsíčník"
RELYING_PARTY_ID="localhost"
RELYING_PARTY_ORIGIN="http://localhost:8080"

# Break-glass password sign-in. The password form is a last-resort emergency path:
# the system treats it as DISABLED whenever this variable is unset or not exactly
# "true". Set "true" until an alternative sign-in method (magic link / OAuth) ships.
ALLOW_PASSWORD_SIGN_IN="true"

# Google OAuth (Workspace SSO). From a Web OAuth client in Google Cloud Console; the
# redirect URI is derived from BASE_URL (…/administration/sign-in/google/callback)
# and must be registered on the client. Required in production — the dummy values
# only satisfy the boot gate; the Google button errors on submit without real ones.
GOOGLE_CLIENT_ID="dummy"
GOOGLE_CLIENT_SECRET="dummy"

# Magic-link email via Google Apps Script (SCRIPT__Auth__Magic_Link web app). Required
# in production. GAS_MAGIC_LINK_URL is the web app /exec URL; GAS_MAGIC_LINK_SECRET
# must match the script's SHARED_SECRET. Dummy values boot the container but no email
# is sent.
GAS_MAGIC_LINK_URL="https://example.com"
GAS_MAGIC_LINK_SECRET="dummy"

# Editorial-board contacts via Google Apps Script (SCRIPT__Editorial_Board__Contacts
# web app). Required in production. GAS_EDITORIAL_BOARD_URL is the web app /exec URL;
# GAS_EDITORIAL_BOARD_SECRET must match the script's SHARED_SECRET. With dummy values
# the /redakce page renders a fallback message.
GAS_EDITORIAL_BOARD_URL="https://example.com"
GAS_EDITORIAL_BOARD_SECRET="dummy"

# Tigris/S3 via local S3Mock (docker compose --profile tigris). Uncomment to route the
# app's object store at the s3mock service instead of the on-disk volume.
# STORE_DRIVER="tigris"
# AWS_ENDPOINT_URL_S3="http://s3mock:9090"
# AWS_REGION="auto"
# BUCKET_NAME="cz-vednemesicnik-storage"
# AWS_ACCESS_KEY_ID="dummy"
# AWS_SECRET_ACCESS_KEY="dummy"

# Sentry error tracking. Public ingest DSN. Unset → the SDK stays inert (no network
# calls). Set it to capture server/client errors from this container.
# Source-map upload is a build-time concern and happens only on deploy, so there is
# no SENTRY_AUTH_TOKEN here — this container's env feeds the runtime, not the image
# build. The local image is intentionally built without upload.
SENTRY_DSN=""
