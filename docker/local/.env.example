SESSION_SECRET="some_session_secret"
HONEYPOT_SECRET="some_honeypot_secret"

# Break-glass password sign-in. Disabled by default; set "true" to enable the
# password form and action in the container. Keep "true" until an alternative
# sign-in method (magic link / OAuth) ships. See issue #112.
ALLOW_PASSWORD_SIGN_IN="true"

# Tigris/S3 via local S3Mock (docker compose --profile tigris). Uncomment to
# route the app's object store at the s3mock service instead of the volume.
# STORE_DRIVER="tigris"
# AWS_ENDPOINT_URL_S3="http://s3mock:9090"
# AWS_REGION="auto"
# BUCKET_NAME="cz-vednemesicnik-storage"
# AWS_ACCESS_KEY_ID="dummy"
# AWS_SECRET_ACCESS_KEY="dummy"